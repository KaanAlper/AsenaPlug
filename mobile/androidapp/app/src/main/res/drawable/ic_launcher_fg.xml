<!-- Adaptive icon foreground: 108dp tuval. gravity=fill -> bitmap inset bounds'a ölçeklenir.
     inset 17dp -> logo ~74dp: squircle/rounded-square (MIUI/Pixel) görünür alanına sığar.
     MIUI'de 84dp kırpıldı, 64dp küçük kaldı -> 74dp ikisinin arası, kırpılmadan belirgin.
     (Kurt şekli köşeleri doldurmaz, o yüzden 66dp güvenli-alanı biraz aşabiliyor.) -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="17dp" android:insetTop="17dp"
    android:insetRight="17dp" android:insetBottom="17dp">
    <bitmap
        android:src="@drawable/asena_logo"
        android:gravity="fill" />
</inset>
